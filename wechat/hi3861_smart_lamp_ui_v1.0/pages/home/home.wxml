<!-- CO₂ 和 TTL 并排显示 -->
<view class="body-timer-wrapper">
  <!-- CO₂ 容器 -->
  <view class="body-timer-style">
    <!-- 左侧 -->
    <view class="body-timer-left">
      <text style="font-size: 20px;">CO₂</text>
      <text>{{ CO2_value }}ppm</text>
    </view>
    <!-- 右侧 -->
    <view class="body-timer-right">
      <image 
        style="width: 40px; height: 40px; margin-top: 11px; margin-right: 5px;" 
        src="../image/co2.png" 
      />
    </view>
  </view>

  <!-- TTL 容器 -->
  <view class="body-timer-style">
    <!-- 左侧 -->
    <view class="body-timer-left">
      <text style="font-size: 20px;">Danger</text>
    </view>
    <!-- 右侧 -->
    <view class="body-timer-right">
      <text class="item-value {{ ttl_status === 'ON' ? 'status-on' : 'status-off' }}">
        {{ ttl_status }}
      </text>
    </view>
  </view>
</view>

