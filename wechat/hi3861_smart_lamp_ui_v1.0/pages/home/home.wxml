<!-- 风扇和电机控制 -->
<view class="body-timer-wrapper">
  <!-- 风扇控制 -->
  <view class="body-timer-style">
    <view class="body-timer-left">
      <text style="font-size: 20px;">Fan</text>
      <text>{{ fan_control_text }}</text>
    </view>
    <view class="body-timer-right">
      <switch 
        bindchange="bind_fan_control_change" 
        checked="{{ fan_control_status }}"
        style="margin-top: 15px; margin-right: 5px;"
      />
    </view>
  </view>

  <!-- 电机控制 -->
  <view class="body-timer-style">
    <view class="body-timer-left">
      <text style="font-size: 20px;">Motor</text>
      <text>{{ motor_control_text }}</text>
    </view>
    <view class="body-timer-right">
      <switch 
        bindchange="bind_motor_control_change" 
        checked="{{ motor_control_status }}"
        style="margin-top: 15px; margin-right: 5px;"
      />
    </view>
  </view>
</view>

<!-- 状态图标行 -->
<view class="body-timer-wrapper">
  <!-- 风扇图标 -->
  <view class="body-timer-style">
    <view class="body-timer-left">
      <text style="font-size: 16px;">Fan status
</text>
    </view>
    <view class="body-timer-right">
      <image 
        style="width: 40px; height: 40px; margin-top: 11px;"
        src="../image/{{ fan_control_status ? 'FAN_ON' : 'FAN_OFF' }}.png"
      />
    </view>
  </view>

  <!-- 电机图标 -->
  <view class="body-timer-style">
    <view class="body-timer-left">
      <text style="font-size: 16px;">Motor status</text>
    </view>
    <view class="body-timer-right">
      <image 
        style="width: 40px; height: 40px; margin-top: 11px;"
        src="../image/{{ motor_control_status ? 'MOTOR_ON' : 'MOTOR_OFF' }}.png"
      />
    </view>
  </view>
</view>


